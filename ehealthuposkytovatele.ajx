      "layer": "business",
      "type": "BusinessService",
      "stereotype": "Rámcová služba",
      "name": "Léčebná rehabilitace",
      "určuje": "§ 9 odst. 2 zákona 372/2011",
      "příznaky": "",
      "description": "v rámci akutní lůžkové péče je poskytována též včasná léčebná rehabilitace"
    },
