    {
      "id": "ehnemobllek",
      "layer": "business",
      "type": "BusinessFunction",
      "stereotype": "Rámcová činnost",
      "name": "Lékárna a příprava léčiv",
      "určuje": "",
      "příznaky": "☑️",
      "description": "Oblast byznysového fungování nemocnice: Nemocnice provozují lékárnu a to jak pro vnitřní potřebu léků, tak i pro klienty i mimo nemocnici. Také zahrnuje přípravu a výdej léčiv a přípravků v režimu lékárny a výdej na eRecept"
