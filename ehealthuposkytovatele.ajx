    {
      "id": "ehealthp1",
      "layer": "motivation",
      "type": "Principle",
      "stereotype": "Architektonický princip",
      "name": "Princip č. 1: Přínos pro pacienta",
      "určuje": "",
      "příznaky": "",
      "description": "Primárním cílem rozvoje elektronického zdravotnictví musí být přínos pro pacienty a kvalitu zdravotní péče."
    },
    {
      "id": "ehealthp2",
      "layer": "motivation",
      "type": "Principle",
      "stereotype": "Architektonický princip",
      "name": "Princip č. 2: Neoslabování práv pacienta",
      "určuje": "",
      "příznaky": "",
      "description": "Právo pacienta na zajištění odpovídající péče, ochranu osobní důstojnosti a ochranu osobních údajů nesmí být zaváděním prostředků elektronického zdravotnictví oslabeno, ale naopak posilováno."
    },
    {
      "id": "ehealthp3",
      "layer": "motivation",
      "type": "Principle",
      "stereotype": "Architektonický princip",
      "name": "Princip č. 3: Participace odborníků na návrzích a řešeních",
      "určuje": "",
      "příznaky": "",
      "description": "Lékaři a další odborní pracovníci ve zdravotnictví musí být zapojováni do projektů již ve fázi přípravy záměrů, při plánování a tvorbě návrhů řešení. Názory odborné veřejnosti musí být v rámci projektů aktivně získávány a přiměřeně zohledňovány."
    },
    {
      "id": "ehealthp4",
      "layer": "motivation",
      "type": "Principle",
      "stereotype": "Architektonický princip",
      "name": "Princip č. 4: Řízení použitelnosti a kvality nástrojů a služeb",
      "určuje": "",
      "příznaky": "",
      "description": "Před zavedením nových nástrojů a služeb elektronického zdravotnictví do praxe musí být vždy dostatečným způsobem ověřena a vyhodnocena jejich použitelnost, kvalita, stabilita a výkonnost."
    },
    {
      "id": "ehealthp5",
      "layer": "motivation",
      "type": "Principle",
      "stereotype": "Architektonický princip",
      "name": "Princip č. 5: Postupné a účelné zavádění služeb",
      "určuje": "",
      "příznaky": "",
      "description": "Zavádění elektronického zdravotnictví na základě plošně stanovené povinnosti je principiálně nesprávné. Při zavádění nových služeb a nástrojů elektronického zdravotnictví je třeba využívat především pozitivní motivace a zavádět nové technologie postupně a uvážlivě tak, aby nedošlo k ohrožení plynulosti a bezpečnosti provozu, ohrožení pacienta nebo zhoršení podmínek práce zdravotníků."
    },
    {
      "id": "ehealthp6",
      "layer": "motivation",
      "type": "Principle",
      "stereotype": "Architektonický princip",
      "name": "Princip č. 6: Standardizace a modernizace",
      "určuje": "",
      "příznaky": "",
      "description": "Všude, kde je to možné a účelné, je třeba při tvorbě nových řešení využívat veškeré dostupné vědecko-výzkumné poznatky a ověřené technologie, včetně standardů pro výměnu a zobrazování zdravotnických informací."
    },
    {
