    },
    {
      "id": "ehnemoblprov",
      "layer": "business",
      "type": "BusinessFunction",
      "stereotype": "Rámcová činnost",
      "name": "Provoz nemocnice",
      "určuje": "",
      "příznaky": "☑️",
      "description": "Oblast byznysového fungování nemocnice: Vše kolem celého provozu nemocnice. Od ICT, majetku, ekonomiky, spisové služby, zakázek až po autoprovoz či prádelny. Tedy vše co není přímo poskytováním zdravotních či sociálních služeb."
    },
    {
